module help

import cli/cli
import cli/help

workflow helpCmd {
  start: HelpCommand

  state HelpCommand {
    action cli/help.Help(command: $command, commands: $commands, requestedCommand: $requestedCommand, commandConfig: $config, config: $config.config, flagSet: $config.flagSet, flags: $config.flags) as Result
    on success -> _
    on failure -> Failed
  }

  state Finish {
    action services/common/response.Response(
      value: $Result??"Help command executed successfully",
      statusCode: 200
    ) as FinalResult
    end ok
  }

  state Failed {
    action services/common/response.Response(
      value: $@.error??"Failed to execute help command",
      statusCode: 500
    ) as ErrorResult
    end fail
  }
}
